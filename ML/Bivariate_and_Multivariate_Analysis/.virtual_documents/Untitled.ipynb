import pandas as pd
import numpy as np
import seaborn as sns


tips = sns.load_dataset('tips')
titanic = pd.read_csv("train.csv")
flights = sns.load_dataset('flights')
iris = sns.load_dataset('iris')


tips.head()





sns.scatterplot(data=tips, x="total_bill", y="tip", hue="sex", style="smoker", size="size")





titanic.sample()


sns.barplot(data=titanic, x="Pclass", y="Age", hue="Sex")





sns.boxplot(data=titanic, x="Sex", y="Age", hue="Survived")





sns.distplot([titanic[titanic["Survived"] == 0]["Age"]], hist=False, kde=True)
sns.distplot([titanic[titanic["Survived"] == 1]["Age"]], hist=False, kde=True)





pd.crosstab(titanic['Pclass'],titanic['Survived'])


sns.heatmap(pd.crosstab(titanic['Pclass'],titanic['Survived']))


(titanic.groupby('Sex').mean(numeric_only=True)['Survived'] * 100)


(titanic.groupby('Embarked').mean(numeric_only=True)['Survived'] * 100)





pd.crosstab(titanic['Parch'],titanic['Survived'])


sns.clustermap(pd.crosstab(titanic['Parch'],titanic['Survived']))





sns.pairplot(iris,hue='species')





new = flights.groupby("year").sum(numeric_only=True).reset_index()


new


sns.lineplot(flights,x='year', y='passengers')


sns.clustermap(flights.pivot_table(values='passengers',index='month',columns='year'))
